@page "/reports"
@using School.Application.DTOs.Reports
@using School.Web.Services
@inject AuthService Auth
@inject NavigationManager Nav
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>Reports</PageTitle>

<h3>Reports</h3>

<div class="d-flex gap-2 mb-3">
    <button class="btn btn-outline-secondary" @onclick="PrintReport">Print</button>
</div>

@if (!Auth.IsLoggedIn)
{
    <p>Redirecting to login...</p>
}
else if (_loading)
{
    <p>Loading reports...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="card p-3">
                <div class="fw-bold">Students with Due</div>
                <div class="display-6">@_studentsWithDue</div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card p-3">
                <div class="fw-bold">Total Due Amount</div>
                <div class="display-6">@_totalDueAmount</div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card p-3">
                <div class="fw-bold">Attendance Records</div>
                <div class="display-6">@_attendanceCount</div>
            </div>
        </div>
    </div>

    <div class="card p-3 mb-4">
        <h5 class="mb-3">Fee Due Report Filter</h5>

        <div class="row g-3">
            <div class="col-12 col-md-4">
                <label class="form-label">Class (optional)</label>
                <input class="form-control" @bind="_feeClassName" placeholder="Example: 10A" />
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary" @onclick="LoadDuesReport">Load Dues Report</button>
            <button class="btn btn-success" @onclick="DownloadDuesExcel">Download Excel</button>
            <button class="btn btn-outline-secondary" @onclick="ClearFeeClassFilter">Clear</button>
        </div>
    </div>

    <div class="card p-3 mb-4">
        <h5 class="mb-3">Attendance Report Filter</h5>

        <div class="row g-3">
            <div class="col-12 col-md-4">
                <label class="form-label">Class</label>
                <input class="form-control" @bind="_attendanceClassName" placeholder="Example: 10A" />
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">From Date</label>
                <input type="date" class="form-control" @bind="_fromDate" />
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">To Date</label>
                <input type="date" class="form-control" @bind="_toDate" />
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary" @onclick="LoadAttendanceReport">Load Attendance Report</button>
            <button class="btn btn-success" @onclick="DownloadAttendanceExcel">Download Excel</button>
            <button class="btn btn-outline-secondary" @onclick="ResetAttendanceFilter">Reset</button>
        </div>
    </div>

    <div class="card p-3 mb-4">
        <h5 class="mb-3">Student Profile Report</h5>

        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label">Student Roll Number</label>
                <input class="form-control" @bind="_studentRollNumber" placeholder="Example: LKG001" />
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary" @onclick="LoadStudentProfileReport">Load Student Profile</button>
            <button class="btn btn-success" @onclick="DownloadStudentProfileExcel">Download Excel</button>
            <button class="btn btn-outline-secondary" @onclick="ClearStudentProfile">Clear</button>
        </div>

        @if (_studentProfile is not null)
        {
            <div class="row g-3 mt-3">
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card p-3">
                        <div class="fw-bold">Student Name</div>
                        <div>@_studentProfile.StudentName</div>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card p-3">
                        <div class="fw-bold">Class</div>
                        <div>@_studentProfile.Class</div>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card p-3">
                        <div class="fw-bold">Age</div>
                        <div>@_studentProfile.Age</div>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card p-3">
                        <div class="fw-bold">Total Fee</div>
                        <div>@_studentProfile.TotalFee</div>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card p-3">
                        <div class="fw-bold">Paid Amount</div>
                        <div>@_studentProfile.PaidAmount</div>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card p-3">
                        <div class="fw-bold">Due Amount</div>
                        <div>@_studentProfile.DueAmount</div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="card p-3">
                        <div class="fw-bold">Present Count</div>
                        <div>@_studentProfile.PresentCount</div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="card p-3">
                        <div class="fw-bold">Absent Count</div>
                        <div>@_studentProfile.AbsentCount</div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="card p-3">
                        <div class="fw-bold">Not Marked Count</div>
                        <div>@_studentProfile.NotMarkedCount</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card p-3 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Fee Due Report</h5>
            <span class="text-muted small">@_duesRows.Count row(s)</span>
        </div>

        @if (_duesRows.Count == 0)
        {
            <div class="card border-0 shadow-sm p-4 text-center">
                <div class="mb-2 fs-4">💰</div>
                <h5 class="mb-2">No dues report data</h5>
                <p class="text-muted mb-0">Try loading the dues report or changing the class filter.</p>
            </div>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Class</th>
                        <th>Total Fee</th>
                        <th>Paid</th>
                        <th>Due</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _duesRows)
                    {
                        <tr>
                            <td>@row.StudentName</td>
                            <td>@row.Class</td>
                            <td>@row.TotalFee</td>
                            <td>@row.PaidAmount</td>
                            <td>@row.DueAmount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="card p-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Attendance Report</h5>
            <span class="text-muted small">@($"{AttendanceItems.Count()} row(s)")</span>
        </div>

        @if (!AttendanceItems.Any())
        {
            <div class="card border-0 shadow-sm p-4 text-center">
                <div class="mb-2 fs-4">📅</div>
                <h5 class="mb-2">No attendance report data</h5>
                <p class="text-muted mb-0">Try loading the attendance report with a valid class and date range.</p>
            </div>
        }
        else
        {
            <div class="mb-3 text-muted small">
                Class: <span class="fw-semibold">@_attendanceReport?.Class</span> |
                From: <span class="fw-semibold">@_attendanceReport?.FromDate.ToString("yyyy-MM-dd")</span> |
                To: <span class="fw-semibold">@_attendanceReport?.ToDate.ToString("yyyy-MM-dd")</span>
            </div>

            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Class</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Marked By</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in AttendanceItems)
                    {
                        <tr>
                            <td>@row.StudentName</td>
                            <td>@row.Class</td>
                            <td>@row.Date.ToString("yyyy-MM-dd")</td>
                            <td>@row.Status</td>
                            <td>@row.MarkedBy</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;

    private List<FeeDueReportItem> _duesRows = new();
    private AttendanceReportResponse? _attendanceReport;
    private StudentProfileReportResponse? _studentProfile;

    private string _studentsWithDue = "0";
    private string _totalDueAmount = "0";
    private string _attendanceCount = "0";

    private string _feeClassName = "";
    private string _attendanceClassName = "10A";
    private DateTime _fromDate = DateTime.Today.AddDays(-7);
    private DateTime _toDate = DateTime.Today;

    private string _studentRollNumber = "";

    private IEnumerable<AttendanceReportItem> AttendanceItems =>
        _attendanceReport?.Items ?? Enumerable.Empty<AttendanceReportItem>();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadAllAsync();
        StateHasChanged();
    }

    private async Task LoadAllAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            await LoadDuesReport();
            await LoadAttendanceReport();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Toast.ShowError("Failed to load reports.");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadDuesReport()
    {
        try
        {
            var client = Auth.GetAuthorizedClient();

            var url = string.IsNullOrWhiteSpace(_feeClassName)
                ? "api/reports/fees/dues"
                : $"api/reports/fees/dues?className={Uri.EscapeDataString(_feeClassName)}";

            var result = await client.GetFromJsonAsync<List<FeeDueReportItem>>(url);

            _duesRows = result ?? new List<FeeDueReportItem>();
            _studentsWithDue = _duesRows.Count.ToString();
            _totalDueAmount = _duesRows.Sum(x => x.DueAmount).ToString("0.##");

            Toast.ShowSuccess("Fee due report loaded.");
        }
        catch
        {
            _duesRows = new();
            _studentsWithDue = "0";
            _totalDueAmount = "0";
            Toast.ShowError("Failed to load fee due report.");
        }
    }

    private async Task LoadAttendanceReport()
    {
        if (string.IsNullOrWhiteSpace(_attendanceClassName))
        {
            Toast.ShowWarning("Please enter class name for attendance report.");
            return;
        }

        if (_fromDate > _toDate)
        {
            Toast.ShowWarning("From Date cannot be greater than To Date.");
            return;
        }

        try
        {
            var client = Auth.GetAuthorizedClient();

            var from = _fromDate.ToString("yyyy-MM-dd");
            var to = _toDate.ToString("yyyy-MM-dd");

            var url =
                $"api/reports/attendance?className={Uri.EscapeDataString(_attendanceClassName)}&fromDate={from}&toDate={to}";

            var result = await client.GetFromJsonAsync<AttendanceReportResponse>(url);

            _attendanceReport = result;
            _attendanceCount = (_attendanceReport?.Items.Count ?? 0).ToString();

            Toast.ShowSuccess("Attendance report loaded.");
        }
        catch
        {
            _attendanceReport = null;
            _attendanceCount = "0";
            Toast.ShowError("Failed to load attendance report.");
        }
    }

    private async Task LoadStudentProfileReport()
    {
        _studentProfile = null;

        if (string.IsNullOrWhiteSpace(_studentRollNumber))
        {
            Toast.ShowWarning("Please enter a valid Roll Number.");
            return;
        }

        try
        {
            var client = Auth.GetAuthorizedClient();
            var result = await client.GetFromJsonAsync<StudentProfileReportResponse>(
                $"api/reports/student/by-roll/{Uri.EscapeDataString(_studentRollNumber)}");

            _studentProfile = result;
            Toast.ShowSuccess("Student profile report loaded.");
        }
        catch
        {
            _studentProfile = null;
            Toast.ShowError("Failed to load student profile report.");
        }
    }

    private void ClearFeeClassFilter()
    {
        _feeClassName = "";
    }

    private void ResetAttendanceFilter()
    {
        _attendanceClassName = "10A";
        _fromDate = DateTime.Today.AddDays(-7);
        _toDate = DateTime.Today;
    }

    private void ClearStudentProfile()
    {
        _studentRollNumber = "";
        _studentProfile = null;
    }

    private async Task DownloadDuesExcel()
    {
        try
        {
            var client = Auth.GetAuthorizedClient();

            var url = string.IsNullOrWhiteSpace(_feeClassName)
                ? "api/reports/fees/dues/excel"
                : $"api/reports/fees/dues/excel?className={Uri.EscapeDataString(_feeClassName)}";

            var res = await client.GetAsync(url);

            if (!res.IsSuccessStatusCode)
            {
                Toast.ShowError("Failed to download fee due Excel.");
                return;
            }

            var bytes = await res.Content.ReadAsByteArrayAsync();
            var fileName = GetFileNameFromResponse(res) ?? "FeeDueReport.xlsx";

            await JS.InvokeVoidAsync(
                "downloadFileFromBytes",
                fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(bytes));
        }
        catch
        {
            Toast.ShowError("Failed to download fee due Excel.");
        }
    }

    private async Task DownloadAttendanceExcel()
    {
        if (string.IsNullOrWhiteSpace(_attendanceClassName))
        {
            Toast.ShowWarning("Please enter class name for attendance report.");
            return;
        }

        if (_fromDate > _toDate)
        {
            Toast.ShowWarning("From Date cannot be greater than To Date.");
            return;
        }

        try
        {
            var client = Auth.GetAuthorizedClient();

            var from = _fromDate.ToString("yyyy-MM-dd");
            var to = _toDate.ToString("yyyy-MM-dd");

            var url =
                $"api/reports/attendance/excel?className={Uri.EscapeDataString(_attendanceClassName)}&fromDate={from}&toDate={to}";

            var res = await client.GetAsync(url);

            if (!res.IsSuccessStatusCode)
            {
                Toast.ShowError("Failed to download attendance Excel.");
                return;
            }

            var bytes = await res.Content.ReadAsByteArrayAsync();
            var fileName = GetFileNameFromResponse(res) ?? "AttendanceReport.xlsx";

            await JS.InvokeVoidAsync(
                "downloadFileFromBytes",
                fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(bytes));
        }
        catch
        {
            Toast.ShowError("Failed to download attendance Excel.");
        }
    }

    private async Task DownloadStudentProfileExcel()
    {
        if (string.IsNullOrWhiteSpace(_studentRollNumber))
        {
            Toast.ShowWarning("Please enter a valid Roll Number.");
            return;
        }

        try
        {
            var client = Auth.GetAuthorizedClient();
            var res = await client.GetAsync(
                $"api/reports/student/by-roll/{Uri.EscapeDataString(_studentRollNumber)}/excel");

            if (!res.IsSuccessStatusCode)
            {
                Toast.ShowError("Failed to download student profile Excel.");
                return;
            }

            var bytes = await res.Content.ReadAsByteArrayAsync();
            var fileName = GetFileNameFromResponse(res) ?? "StudentProfile.xlsx";

            await JS.InvokeVoidAsync(
                "downloadFileFromBytes",
                fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(bytes));
        }
        catch
        {
            Toast.ShowError("Failed to download student profile Excel.");
        }
    }

    private static string? GetFileNameFromResponse(HttpResponseMessage response)
    {
        var contentDisposition = response.Content.Headers.ContentDisposition;
        return contentDisposition?.FileNameStar ?? contentDisposition?.FileName?.Trim('"');
    }

    private async Task PrintReport()
    {
        try
        {
            await JS.InvokeVoidAsync("window.print");
        }
        catch
        {
            Toast.ShowError("Failed to open print dialog.");
        }
    }
}