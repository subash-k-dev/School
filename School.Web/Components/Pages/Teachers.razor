@page "/teachers"
@using School.Web.Services
@using School.Application.DTOs.Teachers
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ToastService Toast

<PageTitle>Teachers</PageTitle>

<h3>Teachers</h3>

@if (!Auth.IsLoggedIn)
{
    <p>Redirecting to login...</p>
}
else if (_loading)
{
    <p>Loading teachers...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    @if (Auth.IsAdmin)
    {
        <div class="mb-3">
            <button class="btn btn-primary" @onclick="GoToAdd">Add Teacher</button>
        </div>
    }

    <div class="mb-3">
        <input class="form-control"
               placeholder="Search by name, subject, or phone..."
               @bind="Search"
               @bind:event="oninput" />
    </div>

    @if (!_teachers.Any())
    {
        <div class="card border-0 shadow-sm p-4 text-center">
            <div class="mb-2 fs-4">👨‍🏫</div>
            <h5 class="mb-2">No teachers added yet</h5>
            <p class="text-muted mb-3">
                Start by creating your first teacher record.
            </p>

            @if (Auth.IsAdmin)
            {
                <div>
                    <button class="btn btn-primary" @onclick="GoToAdd">Add Teacher</button>
                </div>
            }
        </div>
    }
    else if (!FilteredTeachers.Any())
    {
        <div class="card border-0 shadow-sm p-4 text-center">
            <div class="mb-2 fs-4">🔍</div>
            <h5 class="mb-2">No matching teachers found</h5>
            <p class="text-muted mb-3">
                Try a different name, subject, or phone number.
            </p>
            <div>
                <button class="btn btn-outline-secondary" @onclick="ClearSearch">Clear Search</button>
            </div>
        </div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Subject</th>
                    <th>Phone</th>
                    <th style="width:180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in PagedTeachers)
                {
                    <tr>
                        <td>@t.Name</td>
                        <td>@t.Subject</td>
                        <td>@t.Phone</td>
                        <td>
                            @if (Auth.IsAdmin)
                            {
                                <button class="btn btn-sm btn-secondary me-2" @onclick="() => GoToEdit(t.Id)">Edit</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteTeacher(t.Id)">Delete</button>
                            }
                            else
                            {
                                <span class="text-muted">View only</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted small">
                Page @_currentPage of @TotalPages
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="PrevPage"
                        disabled="@(_currentPage <= 1)">
                    Previous
                </button>

                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="NextPage"
                        disabled="@(_currentPage >= TotalPages)">
                    Next
                </button>
            </div>
        </div>
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<TeacherResponse> _teachers = new();

    private string _search = "";
    private string Search
    {
        get => _search;
        set
        {
            _search = value;
            _currentPage = 1;
        }
    }

    private IEnumerable<TeacherResponse> FilteredTeachers =>
        string.IsNullOrWhiteSpace(_search)
            ? _teachers
            : _teachers.Where(t =>
                (t.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (t.Subject?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (t.Phone?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));

    private int _currentPage = 1;
    private int _pageSize = 5;

    private int TotalPages =>
        Math.Max(1, (int)Math.Ceiling(FilteredTeachers.Count() / (double)_pageSize));

    private IEnumerable<TeacherResponse> PagedTeachers =>
        FilteredTeachers
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadTeachersAsync();
        StateHasChanged();
    }

    private async Task LoadTeachersAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            var client = Auth.GetAuthorizedClient();
            var result = await client.GetFromJsonAsync<List<TeacherResponse>>("api/teachers");

            _teachers = result ?? new List<TeacherResponse>();
            _currentPage = 1;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Toast.ShowError("Failed to load teachers.");
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoToAdd() => Nav.NavigateTo("/teachers/add");

    private void GoToEdit(Guid id) => Nav.NavigateTo($"/teachers/edit/{id}");

    private void ClearSearch()
    {
        Search = "";
    }

    private async Task DeleteTeacher(Guid id)
    {
        if (!Auth.IsAdmin)
        {
            _error = "Access denied.";
            Toast.ShowWarning("Access denied.");
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this teacher?");
        if (!confirmed)
            return;

        try
        {
            var client = Auth.GetAuthorizedClient();
            var res = await client.DeleteAsync($"api/teachers/{id}");

            if (!res.IsSuccessStatusCode)
            {
                _error = $"Delete failed: {res.StatusCode}";
                Toast.ShowError("Failed to delete teacher.");
                return;
            }

            Toast.ShowSuccess("Teacher deleted successfully.");
            await LoadTeachersAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Toast.ShowError("Something went wrong while deleting teacher.");
        }
    }

    private void PrevPage()
    {
        if (_currentPage > 1)
            _currentPage--;
    }

    private void NextPage()
    {
        if (_currentPage < TotalPages)
            _currentPage++;
    }
}