@page "/attendance/class/{ClassName}/date/{Date}"
@using System.Text.Json
@inject School.Web.Services.AuthService Auth
@inject NavigationManager Nav

<PageTitle>Class Attendance</PageTitle>

<h3>Class Attendance</h3>

@if (!Auth.IsLoggedIn)
{
    <p>Redirecting to login...</p>
}
else if (_loading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="card p-3 mb-3">
        <div><span class="fw-bold">Class:</span> @ClassName</div>
        <div><span class="fw-bold">Date:</span> @Date</div>
    </div>

    @if (_rows.Count == 0)
    {
        <p>No attendance found.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _rows)
                {
                    <tr>
                        <td>@GetText(r, "studentName", "StudentName", "name", "Name")</td>
                        <td>@GetText(r, "status", "Status")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <button class="btn btn-secondary" @onclick="Back">Back</button>
}

@code {
    [Parameter] public string ClassName { get; set; } = "";
    [Parameter] public string Date { get; set; } = "";

    private bool _loading = true;
    private string? _error;
    private List<JsonElement> _rows = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            var client = Auth.GetAuthorizedClient();
            var res = await client.GetAsync($"api/attendance/class/{ClassName}/date/{Date}");

            if (!res.IsSuccessStatusCode)
            {
                _error = $"Load failed: {res.StatusCode}";
                return;
            }

            var json = await res.Content.ReadAsStringAsync();
            using var doc = JsonDocument.Parse(json);

            _rows = doc.RootElement.ValueKind == JsonValueKind.Array
                ? doc.RootElement.EnumerateArray().Select(e => e.Clone()).ToList()
                : new List<JsonElement>();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void Back() => Nav.NavigateTo("/attendance/mark");

    private static string GetText(JsonElement obj, params string[] keys)
    {
        foreach (var k in keys)
        {
            if (obj.ValueKind == JsonValueKind.Object && obj.TryGetProperty(k, out var p))
                return p.ToString();
        }
        return "";
    }
}