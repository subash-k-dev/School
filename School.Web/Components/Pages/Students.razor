@page "/students"
@using School.Web.Services
@using School.Application.DTOs.Students
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject School.Web.Services.ToastService Toast

<PageTitle>Students</PageTitle>

<h3>Students</h3>

@if (!Auth.IsLoggedIn)
{
    <p>Redirecting to login...</p>
}
else if (_loading)
{
    <p>Loading students...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    @if (Auth.IsAdmin)
    {
        <div class="mb-3">
            <button class="btn btn-primary" @onclick="GoToAdd">Add Student</button>
        </div>
    }

    <div class="mb-3">
        <input class="form-control"
               placeholder="Search by roll number, name or class..."
               @bind="Search"
               @bind:event="oninput" />
    </div>

    @if (!_students.Any())
    {
        <div class="card border-0 shadow-sm p-4 text-center">
            <div class="mb-2 fs-4">📘</div>
            <h5 class="mb-2">No students added yet</h5>
            <p class="text-muted mb-3">
                Start by creating your first student record.
            </p>

            @if (Auth.IsAdmin)
            {
                <div>
                    <button class="btn btn-primary" @onclick="GoToAdd">Add Student</button>
                </div>
            }
        </div>
    }
    else if (!FilteredStudents.Any())
    {
        <div class="card border-0 shadow-sm p-4 text-center">
            <div class="mb-2 fs-4">🔍</div>
            <h5 class="mb-2">No matching students found</h5>
            <p class="text-muted mb-3">
                Try a different name or class in the search box.
            </p>
            <div>
                <button class="btn btn-outline-secondary" @onclick="ClearSearch">Clear Search</button>
            </div>
        </div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Roll Number</th>
                    <th>Name</th>
                    <th>Age</th>
                    <th>Class</th>
                    <th>Total Fee</th>
                    <th style="width:260px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in PagedStudents)
                {
                    <tr>
                        <td>@s.Rollnumber</td>
                        <td>@s.Name</td>
                        <td>@s.Age</td>
                        <td>@s.Class</td>
                        <td>@s.TotalFee</td>
                        <td>
                            @if (Auth.IsAdmin)
                            {
                                <button class="btn btn-sm btn-secondary me-2" @onclick="() => GoToEdit(s.Id)">Edit</button>
                                <button class="btn btn-sm btn-danger me-2" @onclick="() => DeleteStudent(s.Id)">Delete</button>
                                <button class="btn btn-sm btn-success" @onclick="() => GoPayFee(s.Id)">Pay Fee</button>
                            }
                            else
                            {
                                <span class="text-muted">View only</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted small">
                Page @_currentPage of @TotalPages
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="PrevPage"
                        disabled="@(_currentPage <= 1)">
                    Previous
                </button>

                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="NextPage"
                        disabled="@(_currentPage >= TotalPages)">
                    Next
                </button>
            </div>
        </div>
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<StudentResponse> _students = new();

    private string _search = "";
    private string Search
    {
        get => _search;
        set
        {
            _search = value;
            _currentPage = 1;
        }
    }

    private IEnumerable<StudentResponse> FilteredStudents =>
    string.IsNullOrWhiteSpace(_search)
        ? _students
        : _students.Where(s =>
            (s.Rollnumber?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.Class?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));

    private int _currentPage = 1;
    private int _pageSize = 5;

    private int TotalPages =>
        Math.Max(1, (int)Math.Ceiling(FilteredStudents.Count() / (double)_pageSize));

    private IEnumerable<StudentResponse> PagedStudents =>
        FilteredStudents
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize);



    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadStudentsAsync();
        StateHasChanged();
    }

    private async Task LoadStudentsAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            var client = Auth.GetAuthorizedClient();
            var result = await client.GetFromJsonAsync<List<StudentResponse>>("api/students");

            _students = result ?? new List<StudentResponse>();
            _currentPage = 1;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Toast.ShowError("Failed to load students.");
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoToAdd() => Nav.NavigateTo("/students/add");

    private void GoToEdit(Guid id) => Nav.NavigateTo($"/students/edit/{id}");

    private void GoPayFee(Guid id) => Nav.NavigateTo($"/fees/pay/{id}");

    private void ClearSearch()
    {
        Search = "";
    }

    private async Task DeleteStudent(Guid id)
    {
        if (!Auth.IsAdmin)
        {
            _error = "Access denied.";
            Toast.ShowWarning("Access denied.");
            return;
        }

        if (!await ConfirmAsync("Are you sure you want to delete this student?"))
            return;

        try
        {
            var client = Auth.GetAuthorizedClient();
            var res = await client.DeleteAsync($"api/students/{id}");

            if (!res.IsSuccessStatusCode)
            {
                _error = $"Delete failed: {res.StatusCode}";
                Toast.ShowError("Failed to delete student.");
                return;
            }

            Toast.ShowSuccess("Student deleted successfully.");
            await LoadStudentsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Toast.ShowError("Something went wrong while deleting student.");
        }
    }

    private async Task<bool> ConfirmAsync(string message)
    {
        return await JS.InvokeAsync<bool>("confirm", message);
    }

    private void PrevPage()
    {
        if (_currentPage > 1)
            _currentPage--;
    }

    private void NextPage()
    {
        if (_currentPage < TotalPages)
            _currentPage++;
    }
}