@inject School.Web.Services.AuthService Auth
@inject NavigationManager Nav
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">School.Web</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        @if (Auth.IsLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="dashboard">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="students">
                    <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> Students
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="teachers">
                    <span class="bi bi-person-badge-fill-nav-menu" aria-hidden="true"></span> Teachers
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="fees">
                    <span class="bi bi-cash-coin-nav-menu" aria-hidden="true"></span> Fees
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@AttendanceMenuLink">
                    <span class="bi bi-calendar-check-nav-menu" aria-hidden="true"></span> Attendance
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="reports">
                    <span class="bi bi-bar-chart-line-nav-menu" aria-hidden="true"></span> Reports
                </NavLink>
            </div>





            <div class="nav-item px-3 mt-3">
                <button class="btn btn-danger w-100" @onclick="HandleLogout">
                    Logout
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span> Login
                </NavLink>
            </div>
        }

    </nav>
</div>

@code
{
    private string AttendanceMenuLink => "attendance/mark";

    private async Task HandleLogout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    protected override void OnInitialized()
    {
        Auth.OnAuthStateChanged += StateHasChanged;
    }

    public void Dispose()
    {
        Auth.OnAuthStateChanged -= StateHasChanged;
    }
}